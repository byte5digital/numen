includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
    level: 1
    ignoreErrors:
        # Models referenced in migrations but not yet created
        - '#Class App\\Models\\(ApiKey|Webhook) not found#'
    excludePaths:
        - app/Http/Middleware/HandleInertiaRequests.php
